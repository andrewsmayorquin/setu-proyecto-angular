{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": { "files": ["/assets/**", "/icons/**", "/screenshots/**", "/*.(png|jpg|jpeg|svg|webp|ico)"] }
    }
  ],
  "dataGroups": [
    {
      "name": "firebase-realtime",
      "urls": ["https://*.googleapis.com/**", "https://*.firebaseio.com/**"],
      "cacheConfig": { "strategy": "freshness", "maxSize": 30, "maxAge": "1h", "timeout": "5s" }
    }
  ]
}
